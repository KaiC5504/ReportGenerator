<Window x:Class="ReportGenerator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ReportGenerator.Core.Models;assembly=ReportGenerator.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Report Generator"
        Width="1480"
        Height="920"
        WindowState="Maximized"
        MinWidth="1180"
        MinHeight="760">
    <Window.Resources>
        <x:Array x:Key="BlockTypeOptions" Type="{x:Type core:ReportBlockType}">
            <core:ReportBlockType>StaticText</core:ReportBlockType>
            <core:ReportBlockType>MappedField</core:ReportBlockType>
            <core:ReportBlockType>PageNumber</core:ReportBlockType>
        </x:Array>

        <x:Array x:Key="AlignmentOptions" Type="{x:Type core:ReportTextAlignment}">
            <core:ReportTextAlignment>Left</core:ReportTextAlignment>
            <core:ReportTextAlignment>Center</core:ReportTextAlignment>
            <core:ReportTextAlignment>Right</core:ReportTextAlignment>
        </x:Array>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="18,18,18,12"
                Padding="18"
                Background="White"
                BorderBrush="#DEE2E7"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Report Generator"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#44515E"
                               Text="{Binding CurrentTemplatePath}" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Content="New Template"
                            Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Click="NewTemplateButton_OnClick" />
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Content="Open Template"
                            Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Click="OpenTemplateButton_OnClick" />
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Content="Save Template"
                            Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Click="SaveTemplateButton_OnClick" />
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Content="Open Excel"
                            Click="OpenExcelButton_OnClick" />
                    <Button Content="Generate Preview"
                            Click="GeneratePreviewButton_OnClick" />
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Content="Easy Mode"
                            Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            Click="EnableEasyModeButton_OnClick" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="18,0,18,12"
                Padding="16"
                Background="White"
                BorderBrush="#DEE2E7"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border.Resources>
                <Style x:Key="FullModeTabItemStyle" TargetType="TabItem">
                    <Setter Property="FontSize" Value="16" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="24,12" />
                    <Setter Property="MinHeight" Value="48" />
                </Style>

                <Style x:Key="FullModeSecondaryButtonStyle"
                       TargetType="Button"
                       BasedOn="{StaticResource SecondaryButtonStyle}">
                    <Setter Property="FontSize" Value="15" />
                    <Setter Property="Padding" Value="18,10" />
                    <Setter Property="MinHeight" Value="42" />
                </Style>
            </Border.Resources>

            <TabControl SelectedIndex="{Binding SelectedMainTabIndex}"
                        ItemContainerStyle="{StaticResource FullModeTabItemStyle}">
                <TabItem Header="Template"
                         Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TabItem.Resources>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="Padding" Value="16" />
                        </Style>

                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="15" />
                        </Style>

                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="MinHeight" Value="40" />
                        </Style>

                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="MinHeight" Value="40" />
                        </Style>

                        <Style TargetType="CheckBox">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>

                        <Style TargetType="DataGrid">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="RowHeight" Value="38" />
                            <Setter Property="ColumnHeaderHeight" Value="42" />
                        </Style>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </TabItem.Resources>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <GroupBox Header="Page Settings">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Margin="0,0,12,12">
                                        <TextBlock Margin="0,0,0,6" Text="Template Name" />
                                        <TextBox Text="{Binding TemplateName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,12,12">
                                        <TextBlock Margin="0,0,0,6" Text="Page Size" />
                                        <ComboBox ItemsSource="{Binding PageSizes}"
                                                  SelectedItem="{Binding SelectedPageSize}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,12,12">
                                        <TextBlock Margin="0,0,0,6" Text="Orientation" />
                                        <ComboBox ItemsSource="{Binding Orientations}"
                                                  SelectedItem="{Binding SelectedOrientation}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,0,12">
                                        <TextBlock Margin="0,0,0,6" Text="Rows Per Page" />
                                        <TextBox Text="{Binding RowsPerPage, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Margin="0,0,12,0">
                                        <TextBlock Margin="0,0,0,6" Text="Margin Top (mm)" />
                                        <TextBox Text="{Binding MarginTopMm, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Margin="0,0,0,6" Text="Margin Right (mm)" />
                                        <TextBox Text="{Binding MarginRightMm, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Margin="0,0,0,6" Text="Margin Bottom (mm)" />
                                        <TextBox Text="{Binding MarginBottomMm, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="3">
                                        <TextBlock Margin="0,0,0,6" Text="Margin Left (mm)" />
                                        <TextBox Text="{Binding MarginLeftMm, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Grid.Row="1" Header="Header Blocks">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top"
                                                Margin="0,0,0,10"
                                                Orientation="Horizontal">
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Add Header Block"
                                                Click="AddHeaderBlockButton_OnClick" />
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Remove Selected"
                                                Click="RemoveHeaderBlockButton_OnClick" />
                                        <CheckBox Margin="8,8,0,0"
                                                  VerticalAlignment="Center"
                                                  Content="Only show on first page"
                                                  IsChecked="{Binding HeaderOnlyOnFirstPage}" />
                                    </StackPanel>

                                    <DataGrid ItemsSource="{Binding HeaderBlocks}"
                                              SelectedItem="{Binding SelectedHeaderBlock}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridComboBoxColumn Header="Type"
                                                                    Width="110"
                                                                    ItemsSource="{StaticResource BlockTypeOptions}"
                                                                    SelectedItemBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Text"
                                                                Width="*"
                                                                Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Source"
                                                                Width="170"
                                                                Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridComboBoxColumn Header="Alignment"
                                                                    Width="120"
                                                                    ItemsSource="{StaticResource AlignmentOptions}"
                                                                    SelectedItemBinding="{Binding Alignment, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Font Size"
                                                                Width="90"
                                                                Binding="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridCheckBoxColumn Header="Bold"
                                                                    Width="75"
                                                                    Binding="{Binding IsBold}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="2" Header="Detail Table Columns">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top"
                                                Margin="0,0,0,10"
                                                Orientation="Horizontal">
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Add Column"
                                                Click="AddDetailColumnButton_OnClick" />
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Remove Selected"
                                                Click="RemoveDetailColumnButton_OnClick" />
                                        <TextBlock Margin="12,8,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="Header Font Size" />
                                        <TextBox Width="70"
                                                 Text="{Binding DetailHeaderFontSize, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="12,8,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="Content Font Size" />
                                        <TextBox Width="70"
                                                 Text="{Binding DetailContentFontSize, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="12,8,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="Group By" />
                                        <TextBox Width="70"
                                                 Text="{Binding GroupEveryRows, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="8,8,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#5B6570"
                                                   Text="0 = off" />
                                    </StackPanel>

                                    <DataGrid ItemsSource="{Binding DetailColumns}"
                                              SelectedItem="{Binding SelectedDetailColumn}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Header"
                                                                Width="*"
                                                                Binding="{Binding HeaderText, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Source"
                                                                Width="170"
                                                                Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Width Weight"
                                                                Width="110"
                                                                Binding="{Binding WidthWeight, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridComboBoxColumn Header="Alignment"
                                                                    Width="120"
                                                                    ItemsSource="{StaticResource AlignmentOptions}"
                                                                    SelectedItemBinding="{Binding Alignment, UpdateSourceTrigger=PropertyChanged}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>

                            <GroupBox Grid.Row="3" Header="Footer Blocks">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top"
                                                Margin="0,0,0,10"
                                                Orientation="Horizontal">
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Add Footer Block"
                                                Click="AddFooterBlockButton_OnClick" />
                                        <Button Style="{StaticResource FullModeSecondaryButtonStyle}"
                                                Content="Remove Selected"
                                                Click="RemoveFooterBlockButton_OnClick" />
                                    </StackPanel>

                                    <DataGrid ItemsSource="{Binding FooterBlocks}"
                                              SelectedItem="{Binding SelectedFooterBlock}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridComboBoxColumn Header="Type"
                                                                    Width="110"
                                                                    ItemsSource="{StaticResource BlockTypeOptions}"
                                                                    SelectedItemBinding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Text"
                                                                Width="*"
                                                                Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Source"
                                                                Width="170"
                                                                Binding="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridComboBoxColumn Header="Alignment"
                                                                    Width="120"
                                                                    ItemsSource="{StaticResource AlignmentOptions}"
                                                                    SelectedItemBinding="{Binding Alignment, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridTextColumn Header="Font Size"
                                                                Width="90"
                                                                Binding="{Binding FontSize, UpdateSourceTrigger=PropertyChanged}" />
                                            <DataGridCheckBoxColumn Header="Bold"
                                                                    Width="75"
                                                                    Binding="{Binding IsBold}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </GroupBox>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Data"
                         Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <TabItem.Resources>
                        <Style TargetType="GroupBox" BasedOn="{StaticResource {x:Type GroupBox}}">
                            <Setter Property="FontSize" Value="16" />
                            <Setter Property="Padding" Value="16" />
                        </Style>

                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="15" />
                        </Style>

                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Padding" Value="10,8" />
                            <Setter Property="MinHeight" Value="40" />
                        </Style>

                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="MinHeight" Value="40" />
                        </Style>

                        <Style TargetType="CheckBox">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>

                        <Style TargetType="DataGrid">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="RowHeight" Value="38" />
                            <Setter Property="ColumnHeaderHeight" Value="42" />
                        </Style>

                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Style>
                    </TabItem.Resources>

                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox Header="Import Settings">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Margin="0,0,0,6" Text="Excel File" />
                                    <TextBlock Text="{Binding ExcelFilePath}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Margin="0,0,0,6" Text="Mapping Mode" />
                                    <ComboBox ItemsSource="{Binding MappingModes}"
                                              SelectedItem="{Binding SelectedMappingMode}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,6" Text="Header Row" />
                                    <CheckBox Content="First row contains headers"
                                              IsChecked="{Binding HeaderRowEnabled}" />
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <UniformGrid Grid.Row="1"
                                     Margin="0,0,0,16"
                                     Columns="4">
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" BorderBrush="#DEE2E7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#5B6570" Text="Worksheet" />
                                    <TextBlock Margin="0,8,0,0" FontSize="24" FontWeight="SemiBold" Text="{Binding SheetName}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" BorderBrush="#DEE2E7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#5B6570" Text="Rows" />
                                    <TextBlock Margin="0,8,0,0" FontSize="24" FontWeight="SemiBold" Text="{Binding RowCount}" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,10,0" Padding="16" Background="#F8FAFC" BorderBrush="#DEE2E7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#5B6570" Text="Columns" />
                                    <TextBlock Margin="0,8,0,0" FontSize="24" FontWeight="SemiBold" Text="{Binding ColumnCount}" />
                                </StackPanel>
                            </Border>
                            <Border Padding="16" Background="#F8FAFC" BorderBrush="#DEE2E7" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="#5B6570" Text="Feed Channel" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Text="{Binding UpdateSettings.CurrentChannel}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <GroupBox Grid.Row="2" Header="Sample Rows">
                            <DataGrid ItemsSource="{Binding SampleRowsView}"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      CanUserAddRows="False" />
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Preview &amp; Export">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Generate Preview" Click="GeneratePreviewButton_OnClick" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Print" Click="PrintButton_OnClick" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Export PDF" Click="ExportPdfButton_OnClick" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Export Word" Click="ExportWordButton_OnClick" />
                                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Open Excel" Click="OpenExcelButton_OnClick" />
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Content="Check for Updates"
                                        Visibility="{Binding IsEasyMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                        Click="CheckUpdatesButton_OnClick" />
                                <TextBlock Margin="12,8,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#5B6570"
                                           Text="{Binding CurrentReportSummary}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Exit Easy Mode"
                                    HorizontalAlignment="Right"
                                    Visibility="{Binding IsEasyMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="DisableEasyModeButton_OnClick" />
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                BorderBrush="#DEE2E7"
                                BorderThickness="1"
                                Background="#EEF1F4">
                            <DocumentViewer Style="{StaticResource MinimalDocumentViewerStyle}"
                                            Document="{Binding PreviewDocumentForFullMode}" />
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="1"
                Margin="18,18,18,12"
                Padding="16"
                Background="White"
                BorderBrush="#DEE2E7"
                BorderThickness="1"
                CornerRadius="10"
                Visibility="{Binding IsEasyMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Generate Preview" Click="GeneratePreviewButton_OnClick" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Print" Click="PrintButton_OnClick" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Export PDF" Click="ExportPdfButton_OnClick" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Export Word" Click="ExportWordButton_OnClick" />
                        <Button Style="{StaticResource SecondaryButtonStyle}" Content="Open Excel" Click="OpenExcelButton_OnClick" />
                        <TextBlock Margin="12,8,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#5B6570"
                                   Text="{Binding CurrentReportSummary}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="Exit Easy Mode"
                            HorizontalAlignment="Right"
                            Click="DisableEasyModeButton_OnClick" />
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,16,0,0"
                        BorderBrush="#DEE2E7"
                        BorderThickness="1"
                        Background="#EEF1F4">
                    <DocumentViewer Style="{StaticResource MinimalDocumentViewerStyle}"
                                    Document="{Binding PreviewDocumentForEasyMode}" />
                </Border>
            </Grid>
        </Border>

        <Border Background="#90FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="320"
                    Padding="24"
                    Background="White">
                <StackPanel>
                    <TextBlock Margin="0,0,0,12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Text="Working..." />
                    <ProgressBar Height="10"
                                 Minimum="0"
                                 Maximum="100"
                                 IsIndeterminate="{Binding IsBusyProgressIndeterminate}"
                                 Value="{Binding BusyProgressValue}" />
                    <TextBlock Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Text="{Binding StatusMessage}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
